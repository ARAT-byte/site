{% comment %}
  sections/hero-3d.liquid
  AreeqAttire — 3D Spinning Logo Hero Section
  ─────────────────────────────────────────────
  1. Upload areeq-hero.iife.js to Shopify Admin → Content → Files
     (or place it in your theme's /assets/ folder)
  2. Upload logo.svg to your theme's /assets/ folder
  3. Add this section to your homepage via the Shopify theme editor
{% endcomment %}

<style>
  /* Local styles for the hero overlay so we don't pollute the global CSS */
  .areeq-hero-wrapper {
    position: relative;
    width: 100%;
    height: 100vh;
    background: #000000;
    overflow: hidden;
  }

  .areeq-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding-bottom: 3rem; /* Positions the form at the bottom */
    pointer-events: none;
  }

  .areeq-hero-overlay__inner {
    pointer-events: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    padding: 0 1.5rem;
  }

  /* Email form */
  .areeq-notify-form {
    display: flex;
    gap: 0;
    width: min(420px, 90vw);
    border: 1px solid rgba(212,175,55,0.4);
    border-radius: 2px;
    overflow: hidden;
    backdrop-filter: blur(8px);
    background: rgba(0,0,0,0.3);
  }

  .areeq-notify-form input[type="email"] {
    flex: 1;
    padding: 0.85rem 1.2rem;
    background: transparent;
    border: none;
    outline: none;
    color: #fff;
    font-family: inherit;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
  }

  .areeq-notify-form input[type="email"]::placeholder {
    color: rgba(255,255,255,0.3);
  }

  .areeq-notify-form button {
    padding: 0.85rem 1.5rem;
    background: linear-gradient(135deg, #d4af37, #b8962e);
    border: none;
    color: #000;
    font-family: inherit;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .areeq-notify-form button:hover { opacity: 0.85; }

  .areeq-success-msg {
    font-size: 0.85rem;
    color: rgba(212,175,55,0.9);
    letter-spacing: 0.1em;
    display: none;
  }
</style>

<div class="areeq-hero-wrapper">
  <!-- 3D container -->
  <div
    id="areeq-hero-container"
    style="width: 100%; height: 100%; display: block;"
    aria-label="AreeqAttire animated logo"
    role="img"
  ></div>

  <!-- Content Overlay (Form at the bottom) -->
  <div class="areeq-hero-overlay">
    <div class="areeq-hero-overlay__inner">
      {% form 'customer', id: 'areeq-hero-notify-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter, waitlist">
        <div class="areeq-notify-form">
          <input
            type="email"
            name="contact[email]"
            placeholder="Your email address"
            required
            autocomplete="email"
            id="hero-notify-email"
          >
          <button type="submit">Notify Me</button>
        </div>
        {% if form.posted_successfully? %}
          <p class="areeq-success-msg" style="display:block;">
            ✓ &nbsp;You're on the list. We'll be in touch.
          </p>
        {% endif %}
      {% endform %}
    </div>
  </div>
</div>

{%- comment -%} Pass the logo URL as a data attribute to avoid Liquid-in-JS issues {%- endcomment -%}
<script
  id="areeq-hero-script"
  src="{{ 'areeq-hero.iife.js' | asset_url }}"
  data-logo-url="{{ 'logo.svg' | asset_url }}"
  defer
></script>

<script>
  (function () {
    function bootHero() {
      var scriptTag = document.getElementById('areeq-hero-script');
      var logoUrl = scriptTag ? scriptTag.getAttribute('data-logo-url') : '';
      var container = document.getElementById('areeq-hero-container');

      if (window.AreeqHero && container && logoUrl) {
        window.AreeqHero.init(container, logoUrl);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bootHero);
    } else {
      // Script loaded after DOMContentLoaded (defer can fire after)
      bootHero();
    }

    // Also listen for the script load event in case it finishes after DOMContentLoaded
    var s = document.getElementById('areeq-hero-script');
    if (s) {
      s.addEventListener('load', bootHero);
    }
  })();
</script>

{% schema %}
{
  "name": "3D Hero",
  "tag": "section",
  "class": "section-areeq-hero",
  "settings": [],
  "presets": [
    {
      "name": "3D Hero"
    }
  ]
}
{% endschema %}
