{% comment %}
  password.liquid — AreeqAttire Coming Soon Page
  Paste this entire file into: Shopify Admin → Online Store → Themes → Edit code → Templates → password.liquid
{% endcomment %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="AreeqAttire — Coming Soon">
  <title>AreeqAttire — Coming Soon</title>
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      width: 100%; height: 100%;
      background: #000;
      color: #fff;
      font-family: 'Inter', sans-serif;
      overflow: hidden;
    }

    /* ── 3D canvas fills entire viewport ── */
    #areeq-hero-container {
      position: fixed;
      inset: 0;
      z-index: 0;
    }

    /* ── Content overlay ── */
    .overlay {
      position: fixed;
      inset: 0;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      padding-bottom: 10vh;
      pointer-events: none;
    }

    .overlay__inner {
      pointer-events: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      text-align: center;
      padding: 0 1.5rem;
    }

    /* Brand name */
    .brand {
      font-size: clamp(2rem, 6vw, 4.5rem);
      font-weight: 600;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      background: linear-gradient(135deg, #d4af37 0%, #f9e07a 50%, #d4af37 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Typewriter line */
    .tagline {
      font-size: clamp(0.85rem, 2vw, 1.1rem);
      font-weight: 300;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.6);
      overflow: hidden;
      white-space: nowrap;
      border-right: 2px solid rgba(212,175,55,0.8);
      width: 0;
      animation: typewriter 2.5s steps(30) 0.8s forwards,
                 blink 0.75s step-end infinite;
    }

    @keyframes typewriter {
      to { width: 17.5ch; }
    }
    @keyframes blink {
      50% { border-color: transparent; }
    }

    /* Divider */
    .divider {
      width: 60px;
      height: 1px;
      background: linear-gradient(90deg, transparent, #d4af37, transparent);
    }

    /* Email form */
    .notify-form {
      display: flex;
      gap: 0;
      width: min(420px, 90vw);
      border: 1px solid rgba(212,175,55,0.4);
      border-radius: 2px;
      overflow: hidden;
      backdrop-filter: blur(8px);
      background: rgba(0,0,0,0.3);
    }

    .notify-form input[type="email"] {
      flex: 1;
      padding: 0.85rem 1.2rem;
      background: transparent;
      border: none;
      outline: none;
      color: #fff;
      font-family: 'Inter', sans-serif;
      font-size: 0.9rem;
      letter-spacing: 0.05em;
    }

    .notify-form input[type="email"]::placeholder {
      color: rgba(255,255,255,0.3);
    }

    .notify-form button {
      padding: 0.85rem 1.5rem;
      background: linear-gradient(135deg, #d4af37, #b8962e);
      border: none;
      color: #000;
      font-family: 'Inter', sans-serif;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      cursor: pointer;
      transition: opacity 0.2s;
      white-space: nowrap;
    }

    .notify-form button:hover { opacity: 0.85; }

    .success-msg {
      font-size: 0.85rem;
      color: rgba(212,175,55,0.9);
      letter-spacing: 0.1em;
      display: none;
    }

    /* Bottom credit */
    .footer {
      position: fixed;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.2);
    }
  </style>
</head>

<body>
  {%- comment -%}Shopify requires content_for_layout but we hide it behind our custom UI{%- endcomment -%}
  <div style="display:none;">{{ content_for_layout }}</div>

  <!-- 3D Animation Canvas -->
  <div id="areeq-hero-container"></div>

  <!-- Content Overlay -->
  <div class="overlay">
    <div class="overlay__inner">
      <div class="tagline">coming soon</div>
      <div class="divider"></div>

      <!-- Shopify password page notify form -->
      {% form 'customer', id: 'notify-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter, waitlist">
        <div class="notify-form">
          <input
            type="email"
            name="contact[email]"
            placeholder="Your email address"
            required
            autocomplete="email"
            id="notify-email"
          >
          <button type="submit">Notify Me</button>
        </div>
        {% if form.posted_successfully? %}
          <p class="success-msg" style="display:block;">
            ✓ &nbsp;You're on the list. We'll be in touch.
          </p>
        {% endif %}
      {% endform %}
    </div>
  </div>

  <p class="footer">© {{ 'now' | date: '%Y' }} Areeq Attire — All rights reserved</p>

  <!-- 3D Bundle -->
  <script
    id="areeq-hero-script"
    src="{{ 'areeq-hero.iife.js' | asset_url }}"
    data-logo-url="{{ 'logo.svg' | asset_url }}"
    defer
  ></script>

  <script>
    function bootHero() {
      console.log('[AreeqAttire] bootHero triggered!');
      var s = document.getElementById('areeq-hero-script');
      var container = document.getElementById('areeq-hero-container');
      var logoUrl = s ? s.getAttribute('data-logo-url') : '';
      console.log('Variables:', { scriptFound: !!s, containerFound: !!container, logoUrl: logoUrl, AreeqHero: typeof window.AreeqHero });

      if (window.AreeqHero && container && logoUrl) {
        console.log('[AreeqAttire] initializing 3D scene...');
        window.AreeqHero.init(container, logoUrl);
      } else {
        console.error('[AreeqAttire] Failed to initialize:', !window.AreeqHero ? 'AreeqHero missing' : '');
        if (container) container.innerHTML = '<div style="color:red; z-index:9999; position:absolute; top:10px; left:10px;">AreeqHero init failed! Check browser console.</div>';
      }
    }
    document.addEventListener('DOMContentLoaded', bootHero);
    var scr = document.getElementById('areeq-hero-script');
    if (scr) scr.addEventListener('load', bootHero);
  </script>

</body>
</html>
